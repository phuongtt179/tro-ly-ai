# Telegram Bot Token (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini API Key (lấy từ Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# URL public của server (dùng cho webhook Telegram)
# Ví dụ: https://your-app.onrender.com
WEBHOOK_URL=

# Firebase Service Account JSON (encode base64 hoặc dùng file path)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Port (Render/Railway tự set, local dùng 3000)
PORT=3000

# Timezone (cho cron job nhắc việc)
TZ=Asia/Ho_Chi_Minh
